# App metadata
APP_NAME=amaryllis
ENV=development

# Server
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGIN=*
REQUEST_TIMEOUT_SECS=15

# Auth
# RS256 key pair. Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./private.pem
JWT_PUBLIC_KEY_PATH=./public.pem
JWT_ISSUER=amaryllis
REGISTRATION_ENABLED=true
MAX_USERS=0
JWT_TTL_SECS=86400
TOKEN_BLACKLIST_MAX_ENTRIES=100000

# Database
DB_URL=sqlite://data/amaryllis.db

# Logging
LOG_LEVEL=info

# Live runtime
LIVE_OPEN_ORDER_COOLDOWN_SECS=90
LIVE_STALE_OPEN_ORDER_CANCEL_SECS=180
LIVE_STALE_LIMIT_ORDER_REPLACE_SECS=90
LIVE_REPLACE_MAX_ATTEMPTS_PER_WINDOW=3
LIVE_REPLACE_ATTEMPT_WINDOW_SECS=180
LIVE_SUBMITTED_INTENT_RECONCILE_SECS=300
LIVE_RISK_SOFT_DRAWDOWN_PCT=15.0
LIVE_RISK_MEDIUM_DRAWDOWN_PCT=25.0
LIVE_RISK_HARD_DRAWDOWN_PCT=35.0
LIVE_RISK_SOFT_MARGIN_RATIO=0.70
LIVE_RISK_MEDIUM_MARGIN_RATIO=0.82
LIVE_RISK_HARD_MARGIN_RATIO=0.90
LIVE_RISK_SOFT_OPEN_COOLDOWN_MULTIPLIER=2
LIVE_RISK_MEDIUM_REDUCE_POSITIONS_COUNT=1
LIVE_RISK_HARD_CLOSE_WORST_POSITIONS_COUNT=2

# Runtime alerts
# Leave URL empty to disable webhook delivery.
RUNTIME_ALERT_WEBHOOK_URL=
RUNTIME_ALERT_WEBHOOK_AUTH_HEADER=
RUNTIME_ALERT_WEBHOOK_TIMEOUT_SECS=5
RUNTIME_ALERT_WEBHOOK_MAX_RETRIES=3
RUNTIME_ALERT_WEBHOOK_RETRY_BACKOFF_MS=500
RUNTIME_ALERT_WEBHOOK_SIGNING_SECRET=
RUNTIME_ALERT_WEBHOOK_SIGNING_HEADER=X-Amaryllis-Signature
RUNTIME_ALERT_WEBHOOK_SIGNING_TIMESTAMP_HEADER=X-Amaryllis-Timestamp
RUNTIME_ALERT_WEBHOOK_SIGNING_MAX_AGE_SECS=300

# Frontend
VITE_EVENTS_URL=/api/events
